# MiroFish 运行配置（根目录 .env 是唯一手动配置入口）
# 使用方法：
# 1) 复制本文件为 .env
# 2) 先填写密钥（LLM_API_KEY、ZEP_API_KEY），再按需改数据库/Chroma

# ===== 基础运行参数 =====
# SECRET_KEY: Flask 会话签名密钥，生产环境务必改成随机长字符串
SECRET_KEY=mirofish-secret-key
# FLASK_DEBUG: 本地调试用 True，生产建议 False
FLASK_DEBUG=True
# FLASK_HOST / FLASK_PORT: 后端监听地址与端口，默认 0.0.0.0:5001
FLASK_HOST=0.0.0.0
FLASK_PORT=5001

# ===== LLM 主模型配置（必填密钥） =====
# LLM_API_KEY: 你的主模型 API Key（必填）
LLM_API_KEY=your_api_key_here
# LLM_BASE_URL: OpenAI SDK 兼容接口地址
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL_NAME: 主模型名称
LLM_MODEL_NAME=qwen-plus
# LLM_DEFAULT_MAX_TOKENS: 默认最大输出 token
LLM_DEFAULT_MAX_TOKENS=4096

# ===== 可选：LLM 加速/旁路模型 =====
# 不使用可留空；使用时填写完整的 Key、URL、模型名
LLM_BOOST_API_KEY=your_boost_api_key_here
LLM_BOOST_BASE_URL=your_boost_base_url_here
LLM_BOOST_MODEL_NAME=your_boost_model_name_here

# ===== Zep 记忆服务（必填密钥） =====
# ZEP_API_KEY: Zep Cloud 的 API Key（必填）
ZEP_API_KEY=your_zep_api_key_here

# ===== MySQL 数据库 =====
# DATASOURCE_URL: JDBC 风格连接串，包含库名与时区参数
DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/mirofish?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
# DATASOURCE_USERNAME / DATASOURCE_PASSWORD: 数据库账号密码
DATASOURCE_USERNAME=root
DATASOURCE_PASSWORD=123456

# ===== Chroma 向量库 =====
# CHROMA_MODE:
# - persistent: 使用本地磁盘目录（单机默认）
# - http: 连接外部 Chroma 服务
CHROMA_MODE=persistent
# persistent 模式下生效：向量数据落盘目录（相对项目根目录）
CHROMA_PERSIST_DIRECTORY=backend/uploads/chroma
# http 模式下生效：外部 Chroma 地址
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000
# 集合名：默认 world_info，除非你明确要隔离数据，否则不建议改
CHROMA_COLLECTION_NAME=world_info

# ===== Embedding 向量化模型 =====
# EMBEDDING_PROVIDER: 当前实现使用 sentence_transformers
EMBEDDING_PROVIDER=sentence_transformers
# EMBEDDING_MODEL_NAME: 向量模型名称
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
# EMBEDDING_BATCH_SIZE: 向量化批大小，显存/内存不足时可调小
EMBEDDING_BATCH_SIZE=16

# ===== World Info 检索增强参数 =====
# WORLD_INFO_ENABLED: 是否启用 world info 检索增强
WORLD_INFO_ENABLED=true
# CHUNK_SIZE / CHUNK_OVERLAP: 文本切片大小与重叠
WORLD_INFO_CHUNK_SIZE=1200
WORLD_INFO_CHUNK_OVERLAP=200
# SEARCH_TOP_K: 每次检索召回条数
WORLD_INFO_SEARCH_TOP_K=8
# 两类上下文预算（字符数）
SIMULATION_CONTEXT_BUDGET_CHARS=50000
REPORT_CONTEXT_BUDGET_CHARS=20000
# 注入到提示词的最大字符数
WORLD_INFO_INJECTION_CHARS=12000

# ===== 运行调优参数 =====
# OASIS_DEFAULT_MAX_ROUNDS: 默认模拟轮数
OASIS_DEFAULT_MAX_ROUNDS=10
# REPORT_AGENT_*: 报告 Agent 工具调用次数、反思轮次、温度
REPORT_AGENT_MAX_TOOL_CALLS=5
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
REPORT_AGENT_TEMPERATURE=0.5
